# Puerto del servidor
PORT=3000

# Secretos (se generan automáticamente en .env si no existen)
JWT_SECRET=
DATA_ENCRYPTION_KEY=

# OpenAI (opcional: el chatbot funciona con flujos guiados sin esto)
OPENAI_API_KEY=

# Conexión a Neon (PostgreSQL serverless)
DATABASE_URL=postgresql://user:pass@ep-xxxx.neon.tech/dbname?sslmode=require

# Selección por entorno (opcional):
# NODE_ENV=test        -> usa .env.test
# NODE_ENV=production  -> usa .env.production
# ENV_FILE=.env.custom -> fuerza un archivo específico

# Deploy remoto desde SuperAdmin (opcional)
# Si se omiten, el script deploy/remote-deploy.ps1 usa sus valores por defecto.
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PORT=
DEPLOY_REMOTE_APP_DIR=
DEPLOY_SSH_IDENTITY_FILE=
DEPLOY_GIT_REMOTE=origin
DEPLOY_GIT_BRANCH=main
